# ─────────────────────────────────────────────────────────────────────────────
# Open Source Bible environment variables
#
# Copy this file to `.env` and fill in the values you have. The app works with
# NO keys at all for the bundled public-domain translations (KJV / WEB / ASV),
# EXCEPT that relevance ranking needs ONE LLM key (Anthropic or OpenAI).
#
# These are SERVER-SIDE secrets. They are read only inside the Expo Router API
# routes (app/*+api.ts) and are NEVER exposed to the client. Do not prefix them
# with EXPO_PUBLIC_ — that would ship them to the browser/app bundle.
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM provider (relevance ranking) --------------------------------------
# Which provider to use: "anthropic" (default) or "openai".
LLM_PROVIDER=anthropic

# Anthropic (default). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (only used when LLM_PROVIDER=openai). https://platform.openai.com/
OPENAI_API_KEY=

# Optional model override. Defaults per provider:
#   anthropic -> claude-haiku-4-5   (fast + inexpensive; great for this task)
#   openai    -> gpt-4o-mini
# Use a stronger model (e.g. claude-opus-4-8) if you want richer relevance.
LLM_MODEL=

# --- Optional: copyrighted translations (NIV / ESV / NLT / etc.) ------------
# These translations are NOT bundled because their text is under copyright.
# To enable them you must obtain your own license + API key from a provider.
# When unset, the app simply offers the public-domain translations only.
#
# API.Bible (https://scripture.api.bible/) — supports many translations incl.
# licensed ones if your account has access.
BIBLE_API_KEY=
# Comma-separated extra translations to surface in the picker, in the form
# id:Label:bibleId  (bibleId is the API.Bible translation id).
# Example: niv:New International Version:de4e12af7f28f599-02
BIBLE_API_TRANSLATIONS=

# ─────────────────────────────────────────────────────────────────────────────
# Accounts + billing (payments portal) — added incrementally as we build it.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (auth + database) ---
# Create a project at https://supabase.com, then: Project Settings → API.
# URL + anon key are PUBLIC (safe to expose to the client) → EXPO_PUBLIC_ prefix.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SERVER-ONLY (full DB access; never expose to the client).
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin ---
# This email gets unlimited access + the admin dashboard. The password is set in
# Supabase (never stored in this repo). Change the password you shared in chat.
ADMIN_EMAIL=benjamin.shi.contact@gmail.com

# --- Stripe (Phase 3) ---
# From https://dashboard.stripe.com → Developers → API keys, and create two
# recurring Prices: $3.99/month and $19.99/year.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
